---
import * as site from '@data/site';
import { Image } from 'astro:assets';
import storefront from '@assets/storefront.jpg';
---

<section class="hero" id="top">
  <div class="hero-media">
    <Image
      src={storefront}
      alt={`The Meat Center storefront at ${site.address.street}, ${site.address.city}, ${site.address.state}`}
      widths={[640, 960, 1440, 2048]}
      sizes="100vw"
      loading="eager"
      fetchpriority="high"
    />
    <div class="hero-scrim"></div>
  </div>

  <div class="wrap hero-inner">
    <div class="hero-content">
      <p class="eyebrow">Family-Owned Butcher · Lancaster, SC · 40 Years</p>
      <h1 class="hero-headline">
        <span class="sr-only">The Meat Center — </span>Quality Meats. Fresh Seafood. Great Prices.
      </h1>
      <p class="hero-sub">Certified Angus Beef, Wagyu &amp; fresh seafood — fresh every day, never frozen.</p>

      <div class="hero-cta">
        <a class="btn btn-gold btn-lg" href="#special">See this week’s special</a>
        <a class="btn btn-ghost" href={`tel:${site.phoneTel}`}>
          <span aria-hidden="true">📞</span> Call {site.phone}
        </a>
      </div>

      <p class="hero-hours" data-hours-today>
        <a href="#visit">See this week’s hours</a>
      </p>
    </div>
  </div>
</section>

<script>
  // Open/closed status, enhanced client-side so it never goes stale.
  const HOURS: Record<number, [number, number] | null> = {
    0: null, 1: [540, 1080], 2: [540, 1080], 3: [540, 1080],
    4: [540, 1080], 5: [540, 1080], 6: [540, 1020],
  };
  const DAY = ['Sunday', 'Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday', 'Saturday'];
  const fmt = (min: number) => {
    let h = Math.floor(min / 60);
    const m = min % 60;
    const ap = h >= 12 ? 'PM' : 'AM';
    h = h % 12 || 12;
    return `${h}${m ? ':' + String(m).padStart(2, '0') : ''} ${ap}`;
  };
  const el = document.querySelector('[data-hours-today]');
  if (el) {
    const now = new Date();
    const today = HOURS[now.getDay()];
    const mins = now.getHours() * 60 + now.getMinutes();
    let msg: string;
    if (today && mins >= today[0] && mins < today[1]) {
      msg = `<strong class="open">● Open now</strong> · today ${fmt(today[0])}–${fmt(today[1])}`;
    } else if (today) {
      msg = `<strong class="closed">● Closed now</strong> · today ${fmt(today[0])}–${fmt(today[1])}`;
    } else {
      msg = `<strong class="closed">● Closed ${DAY[now.getDay()]}</strong>`;
    }
    el.innerHTML = `${msg} · <a href="#visit">full hours</a>`;
  }
</script>

<style>
  .hero {
    position: relative;
    min-height: min(88vh, 760px);
    display: flex;
    align-items: flex-end;
    color: var(--cream);
    overflow: hidden;
  }
  .hero-media { position: absolute; inset: 0; z-index: 0; }
  .hero-media :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 22%;
  }
  .hero-scrim {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(105deg, rgba(15, 11, 9, 0.72) 0%, rgba(15, 11, 9, 0.48) 38%, rgba(15, 11, 9, 0.08) 68%, rgba(15, 11, 9, 0) 100%),
      linear-gradient(to top, rgba(15, 11, 9, 0.62) 0%, rgba(15, 11, 9, 0.1) 45%, transparent 70%);
  }

  .hero-inner {
    position: relative;
    z-index: 1;
    width: 100%;
    padding-block: clamp(2.5rem, 6vw, 4.5rem);
  }
  .hero-content { max-width: 640px; }
  .hero .eyebrow { color: var(--gold-soft); margin-bottom: 0.9rem; }

  .hero-headline {
    color: #fff;
    text-transform: uppercase;
    font-weight: 700;
    letter-spacing: 0.005em;
    font-size: clamp(2.1rem, 5.4vw, 3.6rem);
    line-height: 1.02;
    margin: 0 0 1rem;
    text-shadow: 0 2px 26px rgba(0, 0, 0, 0.45);
  }
  .hero-sub {
    font-size: 1.08rem;
    max-width: 46ch;
    margin: 0 0 1.75rem;
    color: #ece2d2;
  }
  .hero-cta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-bottom: 1.1rem;
  }
  .hero-hours {
    margin: 0 0 1.4rem;
    font-size: 1rem;
    color: #f1e8d8;
  }
  .hero-hours a { color: var(--gold-soft); }
  .hero-hours :global(.open) { color: #6fe08a; }
  .hero-hours :global(.closed) { color: #ff9b7d; }
</style>
