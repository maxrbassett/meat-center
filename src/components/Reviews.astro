---
import * as site from '@data/site';
import { reviews } from '@data/reviews';
import ReviewCard from '@components/ReviewCard.astro';
---

<section id="reviews" class="reviews" aria-labelledby="reviews-title">
  <div class="wrap">
    <p class="eyebrow">What customers say</p>
    <h2 id="reviews-title" class="section-title">Loved by the locals</h2>

    <div class="ratings">
      <div class="rating-block">
        <p class="stars" aria-hidden="true">★★★★★</p>
        <p class="score"><strong>{site.rating.google}</strong><span>/ 5 on Google</span></p>
        <a class="btn btn-outline" href={site.googleReviewsUrl} target="_blank" rel="noopener">
          Read our Google reviews
        </a>
      </div>
      <div class="rating-block alt">
        <p class="score"><strong>{site.rating.facebookRecommend}</strong><span>recommend on Facebook</span></p>
        <p class="sub">Based on {site.rating.facebookReviewCount} reviews</p>
        <a class="btn btn-gold" href={site.facebookUrl} target="_blank" rel="noopener">
          Visit us on Facebook
        </a>
      </div>
    </div>

    <div class="trust-grid">
      {
        site.trustPoints.map((t) => (
          <div class="trust">
            <span class="trust-icon" aria-hidden="true">{t.icon}</span>
            <h3>{t.title}</h3>
            <p>{t.body}</p>
          </div>
        ))
      }
    </div>

    {
      reviews.length > 0 && (
        <div class="quote-grid">
          {reviews.map((r) => (
            <ReviewCard review={r} />
          ))}
        </div>
      )
    }
  </div>
</section>

<style>
  .reviews { background: var(--cream); }
  .ratings {
    display: grid;
    gap: 1.25rem;
    grid-template-columns: 1fr;
    margin-bottom: 2rem;
  }
  @media (min-width: 640px) { .ratings { grid-template-columns: 1fr 1fr; } }

  .rating-block {
    background: var(--white);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    padding: 1.6rem;
    text-align: center;
    box-shadow: var(--shadow-sm);
  }
  .rating-block.alt { background: var(--charcoal); color: var(--cream); border-color: var(--charcoal); }
  .stars { color: var(--gold); font-size: 1.7rem; letter-spacing: 0.15em; margin: 0 0 0.25rem; }
  .score { margin: 0 0 0.5rem; font-size: 1.05rem; }
  .score strong {
    font-family: var(--font-display);
    font-size: 2.4rem;
    color: var(--red);
    margin-right: 0.4rem;
  }
  .rating-block.alt .score strong { color: var(--gold-soft); }
  .sub { margin: 0 0 1rem; color: #cdc1ac; font-size: 0.95rem; }

  .trust-grid {
    display: grid;
    gap: 1.25rem;
    grid-template-columns: 1fr;
    margin-bottom: 2rem;
  }
  @media (min-width: 560px) { .trust-grid { grid-template-columns: 1fr 1fr; } }
  @media (min-width: 960px) { .trust-grid { grid-template-columns: repeat(4, 1fr); } }

  .trust {
    background: var(--white);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    padding: 1.4rem;
    box-shadow: var(--shadow-sm);
  }
  .trust-icon { font-size: 1.7rem; }
  .trust h3 { color: var(--red); text-transform: uppercase; margin: 0.5rem 0 0.4rem; font-size: 1.08rem; }
  .trust p { margin: 0; color: var(--charcoal-soft); font-size: 0.95rem; }

  .quote-grid {
    display: grid;
    gap: 1.25rem;
    grid-template-columns: 1fr;
  }
  @media (min-width: 720px) { .quote-grid { grid-template-columns: repeat(3, 1fr); } }
</style>
